# ============================================
# MERN Education Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# Database Configuration
# ============================================
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# 
# For MongoDB Atlas (Production/Staging):
# DATABASE_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/mern-education-platform?retryWrites=true&w=majority&minPoolSize=10&maxPoolSize=100&maxIdleTimeMS=60000&serverSelectionTimeoutMS=5000
#
# For Local Development:
DATABASE_URL=mongodb://localhost:27017/mern-education-platform
#
# Connection Pool Settings (included in Atlas URL above):
# - minPoolSize=10: Minimum connections (per requirement 2.1.3)
# - maxPoolSize=100: Maximum connections (per requirement 2.1.3)
# - maxIdleTimeMS=60000: Close idle connections after 60 seconds
# - serverSelectionTimeoutMS=5000: Server selection timeout (5 seconds)
# - retryWrites=true: Automatically retry failed writes
# - w=majority: Write concern (wait for majority of replica set)

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Use strong secrets (minimum 32 characters / 256 bits)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-min-32-characters-required-change-this
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-characters-required-change-this

# Token expiration times
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# Session Configuration
# ============================================
# Session secret for express-session (minimum 32 characters / 256 bits)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-key-min-32-characters-required-change-this

# ============================================
# Payment Gateway Configuration
# ============================================
# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
# Optional if you are using M-PESA only
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Ethiopian Payment Gateways (add as needed)
# TELEBIRR_API_KEY=your_telebirr_api_key
# CBE_BIRR_API_KEY=your_cbe_birr_api_key
# MPESA_CONSUMER_KEY=your_mpesa_consumer_key
# MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
# Legacy aliases supported by the codebase if you already use them:
# MPESA_API_KEY=your_mpesa_consumer_key
# MPESA_PUBLIC_KEY=your_mpesa_consumer_secret
# MPESA_ENVIRONMENT=sandbox  # or production
# MPESA_SHORTCODE=your_mpesa_shortcode
# MPESA_PASSKEY=your_mpesa_passkey
# PUBLIC_BASE_URL=https://your-public-backend-url

# ============================================
# AWS Configuration
# ============================================
# AWS credentials for S3 storage
# Optional until you enable certificate uploads or other S3-backed features
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=mern-education-platform-storage

# ============================================
# Email Service Configuration
# ============================================
# Supported providers: smtp, resend
# Use Resend on Render free services because it works over HTTPS.
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key_here

# Gmail SMTP credentials (optional fallback)
EMAIL_USER=your@gmail.com
# Generate from Google Account > Security > App passwords.
# Use the 16-character password with no spaces.
EMAIL_PASS=abcdefghijklmnop
# Optional. If omitted, application uses EMAIL_USER.
EMAIL_FROM=your@gmail.com

# ============================================
# Redis Configuration
# ============================================
# Redis connection string for caching and session storage
# Format: redis://username:password@host:port
# Optional on Render: if omitted, the API uses in-memory fallback storage
# REDIS_URL=redis://localhost:6379

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# ============================================
# Render Deployment
# ============================================
# Optional on Render. If omitted, the app falls back to RENDER_EXTERNAL_URL automatically.
# Note: Render free web services are a poor fit for Gmail SMTP; use an HTTP email provider or a paid setup for OTP emails.
# PUBLIC_BASE_URL=https://your-api-name.onrender.com
# RENDER_EXTERNAL_URL is injected automatically by Render at runtime

# ============================================
# Rate Limiting Configuration
# ============================================
# Time window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Optional: Additional Configuration
# ============================================
# Sentry DSN for error tracking (production)
# SENTRY_DSN=your_sentry_dsn

# CDN URL for static assets (production)
# CDN_URL=https://cdn.yourdomain.com

# Log level (error, warn, info, debug)
# LOG_LEVEL=info
